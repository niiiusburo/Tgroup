# Copy to api/.env for local Node API (not committed).
JWT_SECRET=change-me-to-a-long-random-hex-string
INVESTOR_JWT_SECRET=change-me-to-a-different-long-random-hex-string
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/tdental_demo
PORT=3002
TZ=Asia/Ho_Chi_Minh
COSMETIC_LOB_ENABLED=true

# Generative AI chat support. Priority: Gemini > OpenAI > DeepSeek.
# DeepSeek works for chat but does not support embeddings; RAG falls back to keyword search.
GEMINI_API_KEY=...
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
OPENAI_API_KEY=sk-...
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_TEMPERATURE=0.5
AI_MAX_TOKENS=1024
AI_RAG_TOP_K=5