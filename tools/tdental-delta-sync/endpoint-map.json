{
  "_meta": {
    "base_url": "https://tamdentist.tdental.vn",
    "auth": {
      "scheme": "bearer",
      "header": "Authorization",
      "format": "Bearer <jwt>"
    },
    "common_response_envelope": {
      "shape": "{ offset, limit, totalItems, items: [...], aggregates }",
      "exceptions": [
        "/api/DotKhamSteps returns a bare JSON array (no envelope, no pagination)"
      ]
    },
    "common_pagination": {
      "style": "offset",
      "param_limit": "limit",
      "param_offset": "offset",
      "limit_zero_means": "return all rows (SPA uses this for dropdowns; works on most endpoints)",
      "default_safe_page_size": 100
    },
    "delta_filter_strategy_notes": [
      "Generic 'writeDate', 'updatedAfter', 'lastUpdated' params are silently IGNORED server-side (verified: returns full count).",
      "Each table has its own server-side business-date filter. Use those when present.",
      "Skinny list rows do NOT expose writeDate. Most DO expose a 'date' or 'dateCreated' or table-specific date field.",
      "For tables without server-side filter (Products, Employees, Companies, ApplicationUsers), full-pull and client-side filter if needed (all <500 rows)."
    ],
    "id_field_default": "id (GUID string)"
  },
