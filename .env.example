# Copy to .env and fill in real values. DO NOT commit .env.
# Database credentials used by both the Postgres container and API DATABASE_URL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-value

# JWT signing secret. Must be a long random string (>=32 chars).
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-hex-string

# Google Places API key (frontend autocomplete + geocoding)
GOOGLE_PLACES_API_KEY=

# Bảng giá (/bang-gia) — live sync from Google Sheets (legacy ctv2checkin sheet).
# Sheet: https://docs.google.com/spreadsheets/d/19YZB-SgpqvI3-hu93xOk0OCDWtUPxrAAfR6CiFpU4GY/edit
PRICING_SYNC_ENABLED=false
PRICING_SYNC_INTERVAL_MS=30000
PRICING_SHEET_ID=19YZB-SgpqvI3-hu93xOk0OCDWtUPxrAAfR6CiFpU4GY
# Service account JSON inline OR file path (readonly spreadsheets scope).
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CREDENTIALS_FILE=
# Where sync writes pricing.json + index.html (default: website/public/bang-gia in dev).
BANG_GIA_OUTPUT_DIR=

# Face ID provider: local uses face-service; compreface uses CompreFace recognition.
FACE_RECOGNITION_PROVIDER=local

# Compreface (set FACE_RECOGNITION_PROVIDER=compreface to use this for Face ID)
COMPREFACE_URL=http://compreface-api
COMPREFACE_API_KEY=
COMPREFACE_BIND_HOST=127.0.0.1
COMPREFACE_HOST_PORT=8002
# Minimum CompreFace detector probability; stricter values reduce background/extra-face noise.
COMPREFACE_DET_PROB_THRESHOLD=0.75

# Face ID local OpenCV service
FACE_SERVICE_URL=http://face-service:8000
FACE_SERVICE_BIND_HOST=127.0.0.1
FACE_SERVICE_HOST_PORT=8001
FACE_RECOGNITION_VERSION=face-recognition-0.39.5
FACE_AUTO_MATCH_THRESHOLD=0.88
FACE_CANDIDATE_THRESHOLD=0.80
FACE_AUTO_MATCH_MARGIN=0.03
# If the top two plausible identities are closer than this, require a rescan instead of staff choice.
FACE_AMBIGUOUS_MATCH_MARGIN=0.06
FACE_MAX_CANDIDATES=3
FACE_MIN_QUALITY=0.55
FACE_DETECTION_THRESHOLD=0.60
# Face ID passive liveness / anti-spoofing (MiniFASNet). OFF by default — turn on
# only after calibrating the threshold with real clinic captures. Fails open
# (skips the check) when the liveness models are absent, so check-in never breaks.
FACE_LIVENESS_ENABLED=false
# Reject when the averaged REAL-face probability is below this (0..1). Lower = more
# permissive (fewer false rejects of real customers); higher = stricter.
FACE_LIVENESS_THRESHOLD=0.5

# Server timezone — MUST be Asia/Ho_Chi_Minh so that PostgreSQL timestamp (without timezone)
# values are parsed consistently and exports match UI display.
TZ=Asia/Ho_Chi_Minh

# Cosmetic LOB v2 feature flag (NK3 only).
# Set to true on tmv.2checkin.com to enable /api/cosmetic/* routes and the LOB toggle.
# Leave false (or unset) on nk.2checkin.com and nk2 to keep Cosmetic hidden.
COSMETIC_LOB_ENABLED=false
# Frontend build flag — must match COSMETIC_LOB_ENABLED. Controls LOB toggle visibility.
VITE_COSMETIC_LOB_ENABLED=false

# NK Photo media service (patient media bridge)
MEDIA_SERVICE_URL=
MEDIA_SERVICE_API_KEY=

# Hosoonline health-checkup images
HOSOONLINE_BASE_URL=https://hosoonline.com
# Optional fallback for the older API-key contract.
HOSOONLINE_API_KEY=
# Current website contract: used by the API proxy to log in, search appointment media, and proxy protected image bytes.
HOSOONLINE_USERNAME=
HOSOONLINE_PASSWORD=
