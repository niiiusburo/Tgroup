{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@controllers/*": ["interfaces/controllers/*"],
      "@services/*": ["application/services/*"],
      "@entities/*": ["domain/entities/*"],
      "@repositories/*": ["infrastructure/repositories/*"],
      "@middlewares/*": ["interfaces/middlewares/*"],
      "@routes/*": ["interfaces/routes/*"],
      "@interfaces/services/*": ["application/interfaces/services/*"],
      "@interfaces/repositories/*": ["application/interfaces/repositories/*"],
      "@helpers/*": ["application/helpers/*"],
      "@typeorm-config": ["infrastructure/typeorm.config.ts"],
      "@dtos/*": ["application/dtos/*"],
      "@express-config": ["config/express.config.ts"],
      "@error-custom/*": ["error-handling/*"],
      "@interfaces/common/*": ["application/interfaces/common/*"],
      "@container/*": ["container/*"],
      "@unit-of-work": ["infrastructure/UnitOfWork.ts"]
    },
    "lib": ["ES2022", "ESNext"],
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./build",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
