{
  "env": {
    "MCP_TIMEOUT": "300000",
    "MCP_TOOL_TIMEOUT": "600000"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update --skip-flows",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash scripts/sync-claude-mem.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status --json",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash scripts/sync-claude-mem.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/prompt-authority-check.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "migration": {
    "from": "kimi-legacy",
    "to": "kimi-code",
    "apiKeyManagement": "console",
    "authMethod": "one-click",
    "target": "Kilo Code"
  }
}
