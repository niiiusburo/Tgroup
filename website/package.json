{
  "name": "tgclinic-website",
  "private": true,
  "version": "0.31.15",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run version && tsc && VITE_APP_VERSION=$(node -p \"require('./package.json').version\") vite build",
    "build:prod": "npm run version && tsc && vite build --mode production",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 99",
    "preview": "vite",
    "version": "node scripts/generate-version.js",
    "version:check": "curl -s http://localhost:5175/version.json | jq .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "../scripts/dev-e2e.sh test",
    "test:e2e:module-audit": "E2E_BASE_URL=http://localhost:5175 E2E_API_BASE_URL=http://localhost:3002 npx playwright test e2e/module-edit-display-audit.spec.ts --project=chromium",
    "test:e2e:module-audit:live": "E2E_BASE_URL=https://nk.2checkin.com E2E_API_BASE_URL=https://nk.2checkin.com npx playwright test e2e/module-edit-display-audit.spec.ts --config=playwright-live.config.ts --project=live-chromium",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "dev:e2e": "../scripts/dev-e2e.sh start",
    "dev:e2e:stop": "../scripts/dev-e2e.sh stop",
    "dev:e2e:status": "../scripts/dev-e2e.sh status"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "clsx": "^2.1.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.4",
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.2.0",
    "use-places-autocomplete": "^4.0.1",
    "xlsx-js-style": "^1.2.0",
    "@tgroup/contracts": "file:../contracts",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/google.maps": "^3.58.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^4.1.3"
  }
}
